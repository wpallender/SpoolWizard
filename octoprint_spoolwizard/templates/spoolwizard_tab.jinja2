<div class="tab_plugin_spoolwizard">
    <h1>SpoolWizard</h1>
    <p>Filament Inventory Manager</p>

    <hr>

    <h3>Active Spool</h3>
    <h4 id="active-name">No Active Spool</h4>
    <p id="active-weight">Select a spool below.</p>

    <div class="spool-box">
        
    </div>

    <hr>
    
    <div class="spool-form">

        <h3>Add New Spool</h3>

        <label>Brand</label><br>
        <input type="text" id="brand" maxlength="30" required><br><br>

        <label>Material</label><br>
        <input type="text" id="material" maxlength="30" required><br><br>

        <label>Color</label><br>
        <input type="text" id="color" maxlength="30" required><br><br>

        <label>Total Weight (g)</label><br>
        <input type="number" id="total_weight" min="1" step="1" required><br><br>

        <label>Remaining Weight (g)</label><br>
        <input type="number" id="remaining_weight" min="1" step="1" required><br><br>

        <button id="save-spool" class="btn btn-primary">
            Save Spool
        </button>

    </div>

    <hr>

    <h3>Spool Inventory</h3>
    
    <div class="inventory-table">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Spool</th>
                    <th>Remaining</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody id="inventory-body">

            </tbody>
        </table>
    </div>
</div>