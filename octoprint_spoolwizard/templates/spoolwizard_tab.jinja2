<div class="tab_plugin_spoolwizard" data-bind="visible: loginState.isUser()">
    <h1>SpoolWizard</h1>
    <p>Filament Inventory Manager</p>

    <hr>

    <h3>Active Spool</h3>
    <h4 id="active-name">No Active Spool</h4>
    <p id="active-weight">Select a spool below.</p>

    <select id="adjust-type">
        <option value="subtract">Use Filament (-)</option>
        <option value="add">Add Filament (+)</option>
    </select>

    <input
        type="number"
        id="adjust-weight"
        min="1"
        step="1"
        placeholder="Amount (g)"
    >

    <button id="adjust" class="btn btn-primary">
        Apply
    </button>

    <div class="spool-box">
        
    </div>

    <hr>
    
    <button id="add-spool" class="btn btn-primary">
        + Add Spool
    </button>

    <hr>

    <h3>Spool Inventory</h3>
    
    <div class="inventory-table">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Spool</th>
                    <th>Remaining</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody id="inventory-body">

            </tbody>
        </table>
    </div>
    
    <div id="spool-modal" class="modal hide fade" tabindex="-1">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal">&times;</button>
            <h3 id="spool-modal-title">Add New Spool</h3>
        </div>

        <div class="modal-body">
            <label>Brand</label><br>
            <input type="text" id="brand" maxlength="30"><br><br>

            <label>Material</label><br>
            <input type="text" id="material" maxlength="30"><br><br>

            <label>Color</label><br>
            <input type="text" id="color" maxlength="30"><br><br>

            <label>Total Weight (g)</label><br>
            <input type="number" id="total_weight" min="1"><br><br>

            <label>Remaining Weight (g)</label><br>
            <input type="number" id="remaining_weight" min="1">
        </div>

        <div class="modal-footer">
            <button class="btn" data-dismiss="modal">Cancel</button>
            <button id="save-spool" class="btn btn-primary">Save</button>
        </div>
    </div>
    
    <div id="history-modal" class="modal hide fade" tabindex="-1">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal">&times;</button>
            <h3 id="history-title">Spool History</h3>
        </div>

        <div class="modal-body">
            <div id="history-content">
                No history available.
            </div>
        </div>

        <div class="modal-footer">
            <button class="btn" data-dismiss="modal">Close</button>
        </div>
    </div>
</div>
